# Copy to .env on the server and fill in values. chmod 600 .env
# Binance (spot API; used by data feed and live orders when paper_trading is false)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# SendGrid (free tier at sendgrid.com — create an API key under Settings > API Keys)
# EMAIL_SENDER must match a verified sender identity in your SendGrid account
SENDGRID_API_KEY=
EMAIL_SENDER=
EMAIL_RECEIVER=
